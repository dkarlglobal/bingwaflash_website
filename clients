<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Register as Client — Bingwa Flash</title>
<link rel="icon" type="image/png" href="/logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --amber:#f59e0b;--amber-light:#fcd34d;--amber-dark:#d97706;
  --red:#ef4444;--red-bg:rgba(239,68,68,.08);
  --green:#10b981;--green-bg:rgba(16,185,129,.08);
  --amber-bg:rgba(245,158,11,.1);
  --r4:4px;--r8:8px;--r12:12px;--r16:16px;--r24:24px
}
[data-theme="dark"]{
  --bg:#09090b;--surface:#111113;--surface2:#18181b;
  --border:#27272a;--border2:#3f3f46;
  --text:#fafafa;--text2:#a1a1aa;--text3:#71717a;
  --hbg:rgba(9,9,11,.9);--input-bg:#18181b;--btn-ghost-hover:#27272a
}
[data-theme="light"]{
  --bg:#ffffff;--surface:#fafafa;--surface2:#f4f4f5;
  --border:#e4e4e7;--border2:#d4d4d8;
  --text:#09090b;--text2:#52525b;--text3:#a1a1aa;
  --hbg:rgba(255,255,255,.9);--input-bg:#ffffff;--btn-ghost-hover:#f4f4f5
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Plus Jakarta Sans',sans-serif;
  line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased;
  transition:background .25s,color .25s;min-height:100vh;display:flex;flex-direction:column}

/* ── Header ── */
header{position:sticky;top:0;z-index:100;background:var(--hbg);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);padding:0 40px;height:60px;
  display:flex;align-items:center;justify-content:space-between;transition:background .25s}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-icon{width:32px;height:32px;background:var(--amber);border-radius:var(--r8);
  display:flex;align-items:center;justify-content:center;flex-shrink:0}
.logo-icon svg{width:18px;height:18px}
.logo-name{font-family:'Space Grotesk',sans-serif;font-size:.95rem;font-weight:700;
  letter-spacing:-.01em;color:var(--text)}
.logo-name span{color:var(--amber)}
.nav-end{display:flex;align-items:center;gap:8px}
.theme-toggle{width:34px;height:34px;border-radius:var(--r8);background:transparent;
  border:1px solid var(--border);color:var(--text2);cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:border-color .15s,color .15s}
.theme-toggle:hover{border-color:var(--border2);color:var(--text)}

/* ── Agent bar ── */
.agent-bar{padding:16px 24px;border-bottom:1px solid var(--border);
  display:none;align-items:center;gap:12px;background:var(--surface2)}
.ag-av{width:40px;height:40px;border-radius:50%;background:var(--amber);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;color:#000}
.ag-name{font-size:.92rem;font-weight:600;color:var(--text)}
.ag-handle{font-size:.78rem;color:var(--text3)}
.ag-badge{margin-left:auto;display:flex;align-items:center;gap:5px;
  font-size:.73rem;font-weight:500}
.ag-dot{width:6px;height:6px;border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.dot-green{background:var(--green)}.dot-green~span{color:var(--green)}
.dot-red{background:var(--red)}.dot-red~span{color:var(--red)}

/* ── Main layout ── */
main{flex:1;display:flex;align-items:flex-start;justify-content:center;padding:40px 20px 60px;gap:32px;flex-wrap:wrap}

/* ── Card ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r16);
  width:100%;max-width:480px;overflow:hidden;animation:fadeUp .4s ease both}
.card-header{padding:20px 24px 0}
.card-title{font-family:'Space Grotesk',sans-serif;font-size:1.15rem;font-weight:700;
  color:var(--text);margin-bottom:4px}
.card-sub{font-size:.82rem;color:var(--text3)}
.card-body{padding:20px 24px 24px}

/* ── Loading / states ── */
#loading{text-align:center;padding:32px 0}
.spin{width:32px;height:32px;border:2px solid var(--border2);border-top-color:var(--amber);
  border-radius:50%;animation:spin .7s linear infinite;display:inline-block;margin-bottom:12px}
@keyframes spin{to{transform:rotate(360deg)}}
.spin-label{font-size:.8rem;color:var(--text3)}
#error-state,#success-state,#delete-state{display:none}

/* ── Form ── */
#reg-form,#del-form{display:none}
.field{margin-bottom:16px}
.field label{display:block;font-size:.75rem;font-weight:600;color:var(--text2);margin-bottom:6px}
.field input{width:100%;background:var(--input-bg);border:1px solid var(--border);
  border-radius:var(--r8);padding:11px 14px;color:var(--text);font-family:inherit;font-size:.88rem;
  outline:none;transition:border-color .15s}
.field input:focus{border-color:var(--amber)}
.field input.error-ring{border-color:var(--red)}
.field input::placeholder{color:var(--text3)}
.field-hint{font-size:.72rem;color:var(--text3);margin-top:4px}
.field-warn{font-size:.72rem;color:var(--amber);margin-top:4px;display:none}

/* Name case warning */
.name-preview{font-size:.78rem;margin-top:6px;padding:8px 10px;border-radius:var(--r8);
  background:var(--amber-bg);border:1px solid rgba(245,158,11,.2);display:none}
.name-preview span{font-weight:700;color:var(--amber)}

/* ── Inline error / success ── */
.form-err{font-size:.8rem;color:var(--red);margin-bottom:12px;display:none;
  background:var(--red-bg);padding:10px 12px;border-radius:var(--r8)}
.form-ok{font-size:.8rem;color:var(--green);margin-bottom:12px;display:none;
  background:var(--green-bg);padding:10px 12px;border-radius:var(--r8)}

/* ── Buttons ── */
.btn-primary{width:100%;padding:13px;background:var(--amber);color:#000;font-weight:700;
  font-size:.88rem;border:none;border-radius:var(--r8);cursor:pointer;
  transition:opacity .15s;font-family:inherit}
.btn-primary:hover{opacity:.88}
.btn-primary:disabled{opacity:.45;cursor:not-allowed}
.btn-outline-red{width:100%;padding:12px;background:transparent;
  border:1px solid rgba(239,68,68,.4);color:var(--red);font-weight:600;
  font-size:.88rem;border-radius:var(--r8);cursor:pointer;
  transition:background .15s;font-family:inherit}
.btn-outline-red:hover{background:var(--red-bg)}
.btn-outline-red:disabled{opacity:.45;cursor:not-allowed}
.btn-ghost{background:transparent;border:none;color:var(--text3);font-family:inherit;
  font-size:.8rem;cursor:pointer;padding:6px 0;text-decoration:underline;
  transition:color .15s}
.btn-ghost:hover{color:var(--text2)}

/* ── Divider ── */
.divider{border:none;border-top:1px solid var(--border);margin:20px 0}

/* ── Registered agents list ── */
.agents-section{display:none;margin-top:8px}
.agents-label{font-size:.75rem;font-weight:600;color:var(--text2);margin-bottom:10px}
.agent-item{display:flex;align-items:center;gap:10px;padding:10px 12px;
  background:var(--surface2);border:1px solid var(--border);border-radius:var(--r8);
  margin-bottom:6px}
.agent-item-av{width:32px;height:32px;border-radius:50%;background:var(--amber);
  display:flex;align-items:center;justify-content:center;
  font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.8rem;color:#000;flex-shrink:0}
.agent-item-name{font-size:.85rem;font-weight:600;color:var(--text);flex:1}
.agent-item-handle{font-size:.75rem;color:var(--text3)}
.btn-remove{background:transparent;border:1px solid rgba(239,68,68,.35);
  color:var(--red);font-size:.73rem;font-weight:600;padding:4px 10px;
  border-radius:var(--r4);cursor:pointer;transition:background .15s;font-family:inherit}
.btn-remove:hover{background:var(--red-bg)}
.agent-limit-note{font-size:.73rem;color:var(--text3);margin-top:8px}
.limit-hit{color:var(--red);font-weight:600}

/* ── Success / Error states ── */
.state-icon{font-size:2.2rem;margin-bottom:12px}
.state-title{font-family:'Space Grotesk',sans-serif;font-size:1.05rem;font-weight:700;
  color:var(--text);margin-bottom:6px}
.state-desc{font-size:.83rem;color:var(--text2);line-height:1.65;margin-bottom:16px}
.state-detail{font-size:.78rem;color:var(--text3);font-family:monospace;margin-bottom:16px}

/* ── Footer ── */
footer{border-top:1px solid var(--border);padding:40px;display:grid;
  grid-template-columns:auto 1fr auto;align-items:center;gap:24px}
.ft-brand{display:flex;align-items:center;gap:8px;text-decoration:none}
.ft-brand-name{font-family:'Space Grotesk',sans-serif;font-size:.85rem;font-weight:600;color:var(--text)}
.ft-links{display:flex;gap:24px;justify-content:center;flex-wrap:wrap}
.ft-links a{font-size:.8rem;color:var(--text3);text-decoration:none;transition:color .15s}
.ft-links a:hover{color:var(--text2)}
.ft-copy{font-size:.75rem;color:var(--text3);text-align:right}

@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
@media(max-width:768px){
  header{padding:0 20px}
  footer{grid-template-columns:1fr;text-align:center}
  .ft-links{justify-content:center}
  .ft-copy{text-align:center}
}
</style>
</head>
<body>
<header>
  <a class="logo" href="/">
    <div class="logo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
    <span class="logo-name">Bingwa <span>Flash</span></span>
  </a>
  <div class="nav-end">
    <button class="theme-toggle" id="tb" onclick="toggleTheme()" title="Toggle theme"></button>
  </div>
</header>

<!-- Agent bar -->
<div id="agent-bar" class="agent-bar" style="display:none">
  <div class="ag-av" id="ag-av">?</div>
  <div>
    <div class="ag-name" id="ag-name"></div>
    <div class="ag-handle" id="ag-handle"></div>
  </div>
  <div class="ag-badge" id="ag-badge">
    <div class="ag-dot dot-green"></div><span>Online</span>
  </div>
</div>

<main>
<div class="card">
  <div class="card-header">
    <div class="card-title" id="card-title">Register as Client</div>
    <div class="card-sub" id="card-sub">Loading agent…</div>
  </div>
  <div class="card-body">

    <!-- Loading -->
    <div id="loading"><div class="spin"></div><div class="spin-label">Loading…</div></div>

    <!-- Error state -->
    <div id="error-state" style="text-align:center;padding:24px 0">
      <div class="state-icon">⚡</div>
      <div class="state-title" id="err-title">Something went wrong</div>
      <div class="state-desc" id="err-desc">Unable to load this page.</div>
    </div>

    <!-- Success state (after registration) -->
    <div id="success-state" style="text-align:center;padding:24px 0">
      <div class="state-icon">✅</div>
      <div class="state-title">You're Registered!</div>
      <div class="state-desc" id="success-desc">You are now a client of this agent. They can now recommend data offers to your number.</div>
      <button class="btn-ghost" onclick="location.reload()">Back to page</button>
    </div>

    <!-- Delete success state -->
    <div id="delete-state" style="text-align:center;padding:24px 0">
      <div class="state-icon">🗑️</div>
      <div class="state-title">Removed Successfully</div>
      <div class="state-desc" id="delete-desc">You have been removed from this agent's client list.</div>
      <button class="btn-ghost" onclick="location.reload()">Back to page</button>
    </div>

    <!-- Registration form -->
    <div id="reg-form">
      <div class="field">
        <label for="reg-name">Your Full Name</label>
        <input
          type="text"
          id="reg-name"
          placeholder="e.g. John Doe"
          autocomplete="name"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          oninput="onNameInput()"
        >
        <!-- Live name preview — shows exactly how name will be stored -->
        <div class="name-preview" id="name-preview">
          Will be stored as: <span id="name-preview-val"></span>
        </div>
        <div class="field-hint">⚠️ Name is case-sensitive — type it exactly as you want it stored. If you type "john doe" it will be stored as "john doe".</div>
      </div>

      <div class="field">
        <label for="reg-phone">Your Phone Number</label>
        <input
          type="tel"
          id="reg-phone"
          placeholder="07xxxxxxxx or 01xxxxxxxx"
          inputmode="numeric"
          maxlength="10"
          oninput="this.value=this.value.replace(/\D/g,'')"
        >
        <div class="field-hint">Safaricom number only. Must start with 07 or 01.</div>
      </div>

      <div id="reg-err" class="form-err"></div>
      <div id="reg-ok"  class="form-ok"></div>

      <button class="btn-primary" id="reg-btn" onclick="submitRegistration()">
        Register as <span id="register-btn-agent">Agent's</span> Client
      </button>

      <div style="margin-top:10px;text-align:center">
        <button class="btn-ghost" onclick="showDeleteSection()">I want to remove myself from an agent →</button>
      </div>
    </div>

    <!-- Delete self form -->
    <div id="del-form">
      <div class="divider"></div>
      <div style="margin-bottom:16px">
        <div style="font-size:.88rem;font-weight:600;color:var(--text);margin-bottom:4px">Remove yourself from an agent</div>
        <div style="font-size:.78rem;color:var(--text3)">Enter your phone number to look up your registrations and remove yourself.</div>
      </div>

      <div class="field">
        <label for="del-phone">Your Phone Number</label>
        <input
          type="tel"
          id="del-phone"
          placeholder="07xxxxxxxx or 01xxxxxxxx"
          inputmode="numeric"
          maxlength="10"
          oninput="this.value=this.value.replace(/\D/g,'')"
        >
      </div>

      <div id="del-err" class="form-err"></div>

      <button class="btn-primary" id="del-lookup-btn" onclick="lookupMyAgents()" style="margin-bottom:8px">
        Look Up My Registrations
      </button>

      <!-- My registered agents list -->
      <div class="agents-section" id="my-agents-section">
        <div class="agents-label">Your registered agents:</div>
        <div id="my-agents-list"></div>
        <div class="agent-limit-note" id="limit-note"></div>
      </div>

      <div style="margin-top:10px;text-align:center">
        <button class="btn-ghost" onclick="showRegSection()">← Back to registration</button>
      </div>
    </div>

  </div>
</div>
</main>

<footer>
  <a class="ft-brand" href="/">
    <div class="logo-icon" style="width:24px;height:24px;border-radius:6px">
      <svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round" width="14" height="14"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    </div>
    <span class="ft-brand-name">Bingwa Flash</span>
  </a>
  <div class="ft-links">
    <a href="/">Home</a>
    <a href="/privacy.html">Privacy Policy</a>
  </div>
  <div class="ft-copy">© 2026 Bingwa Flash</div>
</footer>

<script type="module">
// ─── Firebase SDK ─────────────────────────────────────────────────────────────
import { initializeApp }         from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import {
  getFirestore,
  doc,
  getDoc,
  setDoc,
  deleteDoc,
  collection,
  query,
  where,
  getDocs,
  serverTimestamp
} from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

// ─── Firebase config (same project as existing index.html) ───────────────────
const FC = {
  apiKey:            "AIzaSyBMf_Kc6gFA30TiiqTvPGEUOHRD0ikpL9c",
  authDomain:        "bingwa-flash.firebaseapp.com",
  projectId:         "bingwa-flash",
  storageBucket:     "bingwa-flash.firebasestorage.app",
  messagingSenderId: "141272100218",
  appId:             "1:141272100218:web:bcfc60bfd8e5945cedbac3"
};

const app = initializeApp(FC);
const db  = getFirestore(app);

// ─── Constants ────────────────────────────────────────────────────────────────
const MAX_AGENTS = 3;  // a client can register under at most 3 agents

// ─── State ───────────────────────────────────────────────────────────────────
const params       = new URLSearchParams(window.location.search);
const AGENT_SLUG   = (params.get("u") || params.get("agent") || "").toLowerCase().trim();
// Also support path-based routing: /agentWebsiteUsername
// e.g. bingwaflash.co.ke/bingwasokoni → extract from pathname
const pathAgent    = (window.location.pathname.replace(/^\//, "").split("/")[0] || "").toLowerCase();
const USERNAME     = AGENT_SLUG || pathAgent;

let agentProfile   = null;
let agentUid       = null;
let agentDocId     = null;

// ─── Helpers ──────────────────────────────────────────────────────────────────
const $ = id => document.getElementById(id);

function showError(title, desc) {
  $("loading").style.display   = "none";
  $("reg-form").style.display  = "none";
  $("del-form").style.display  = "none";
  $("error-state").style.display = "block";
  $("err-title").textContent = title;
  $("err-desc").textContent  = desc;
}

function valid07(p) {
  return /^(07|01)\d{8}$/.test(p.trim());
}

function setLoading(btnId, loading, label) {
  const btn = $(btnId);
  btn.disabled    = loading;
  btn.textContent = loading ? "Please wait…" : label;
}

// ─── Init ─────────────────────────────────────────────────────────────────────
async function init() {
  if (!USERNAME) {
    showError("No agent specified", "This link doesn't include an agent username. Please ask your agent for the correct link.");
    return;
  }

  try {
    // Look up agent by websiteUsername field
    const q    = query(collection(db, "agents"), where("websiteUsername", "==", USERNAME));
    const snap = await getDocs(q);

    if (snap.empty) {
      showError("Agent not found", `No agent with username "${USERNAME}" was found. Please check the link.`);
      return;
    }

    agentDocId  = snap.docs[0].id;
    agentProfile = snap.docs[0].data();
    agentUid    = agentProfile.uid || agentDocId;

    // Update header
    const displayName = agentProfile.agentName || agentProfile.username || USERNAME;
    $("ag-av").textContent      = displayName.charAt(0).toUpperCase();
    $("ag-name").textContent    = displayName;
    $("ag-handle").textContent  = "@" + (agentProfile.websiteUsername || USERNAME);
    $("agent-bar").style.display = "flex";

    // Update card title
    $("card-title").textContent = `Register as ${displayName}'s Client`;
    $("card-sub").textContent   = `You'll be added to ${displayName}'s client list and receive personalised data offers.`;
    $("register-btn-agent").textContent = displayName + "'s";

    $("loading").style.display  = "none";
    $("reg-form").style.display = "block";

  } catch (e) {
    showError("Failed to load", e.message);
  }
}

// ─── Name input live preview ──────────────────────────────────────────────────
window.onNameInput = function() {
  const val = $("reg-name").value;
  const preview = $("name-preview");
  const previewVal = $("name-preview-val");

  if (val.trim().length > 0) {
    previewVal.textContent = val;
    preview.style.display = "block";
  } else {
    preview.style.display = "none";
  }
};

// ─── Section toggles ─────────────────────────────────────────────────────────
window.showDeleteSection = function() {
  $("reg-form").style.display = "none";
  $("del-form").style.display = "block";
};

window.showRegSection = function() {
  $("del-form").style.display = "none";
  $("reg-form").style.display = "block";
};

// ─── REGISTRATION ─────────────────────────────────────────────────────────────
window.submitRegistration = async function() {
  const name  = $("reg-name").value.trim();   // kept exactly as typed
  const phone = $("reg-phone").value.trim();
  const errEl = $("reg-err");
  const okEl  = $("reg-ok");
  errEl.style.display = "none";
  okEl.style.display  = "none";

  // Validation
  if (!name) {
    errEl.textContent = "Please enter your full name.";
    errEl.style.display = "block";
    return;
  }
  if (!valid07(phone)) {
    errEl.textContent = "Enter a valid Safaricom number starting with 07 or 01.";
    errEl.style.display = "block";
    return;
  }

  setLoading("reg-btn", true, "");

  try {
    // ── Check how many agents this phone is already registered under ──────
    const existingSnap = await getDocs(
      query(collection(db, "clientRegistrations"), where("phone", "==", phone))
    );

    const existingDocs   = existingSnap.docs;
    const alreadyUnderThisAgent = existingDocs.find(d => d.data().agentUid === agentUid);

    if (alreadyUnderThisAgent) {
      errEl.textContent = "You are already registered as a client of this agent.";
      errEl.style.display = "block";
      setLoading("reg-btn", false, `Register as ${agentProfile.agentName || USERNAME}'s Client`);
      return;
    }

    if (existingDocs.length >= MAX_AGENTS) {
      errEl.innerHTML = `You are already registered under ${MAX_AGENTS} agents (the maximum).<br>
        Go to "Remove myself from an agent" below to free up a slot first.`;
      errEl.style.display = "block";
      setLoading("reg-btn", false, `Register as ${agentProfile.agentName || USERNAME}'s Client`);
      return;
    }

    // ── Write to clientRegistrations/{phone}_{agentUid} ───────────────────
    const regId  = `${phone}_${agentUid}`;
    const regRef = doc(db, "clientRegistrations", regId);

    await setDoc(regRef, {
      phone:         phone,
      name:          name,          // stored EXACTLY as typed — case sensitive
      agentUid:      agentUid,
      agentUsername: agentProfile.websiteUsername || USERNAME,
      agentName:     agentProfile.agentName || USERNAME,
      registeredAt:  serverTimestamp(),
      registrationId: regId
    });

    // ── Also write to agents/{agentUid}/clients/{phone} ───────────────────
    // This is the sub-collection the app listens to in real-time
    const clientRef = doc(db, "agents", agentUid, "clients", phone);

    await setDoc(clientRef, {
      phone:          phone,
      name:           name,         // exact case — as registered
      totalSpent:     0,
      lastSeenAtMs:   Date.now(),
      isBlacklisted:  false,
      source:         "website",
      maskedDigits:   buildFingerprint(phone),
      registrationId: regId,
      updatedAtMs:    Date.now()
    }, { merge: true });

    // ── Show success ───────────────────────────────────────────────────────
    $("reg-form").style.display    = "none";
    $("success-state").style.display = "block";
    $("success-desc").textContent  =
      `You're now registered as a client of ${agentProfile.agentName || USERNAME}. ` +
      `When you make a payment, they can recommend data offers to ${phone}.`;

  } catch (e) {
    errEl.textContent = "Registration failed: " + e.message;
    errEl.style.display = "block";
    setLoading("reg-btn", false, `Register as ${agentProfile.agentName || USERNAME}'s Client`);
  }
};

// ─── LOOKUP MY AGENTS ─────────────────────────────────────────────────────────
window.lookupMyAgents = async function() {
  const phone = $("del-phone").value.trim();
  const errEl = $("del-err");
  errEl.style.display = "none";

  if (!valid07(phone)) {
    errEl.textContent = "Enter a valid Safaricom number starting with 07 or 01.";
    errEl.style.display = "block";
    return;
  }

  setLoading("del-lookup-btn", true, "");

  try {
    const snap = await getDocs(
      query(collection(db, "clientRegistrations"), where("phone", "==", phone))
    );

    const section  = $("my-agents-section");
    const listEl   = $("my-agents-list");
    const limitEl  = $("limit-note");
    listEl.innerHTML = "";

    if (snap.empty) {
      listEl.innerHTML = `<div style="font-size:.82rem;color:var(--text3);padding:12px 0">
        No registrations found for ${phone}.
      </div>`;
    } else {
      snap.docs.forEach(d => {
        const data = d.data();
        const item = document.createElement("div");
        item.className = "agent-item";
        item.innerHTML = `
          <div class="agent-item-av">${(data.agentName || data.agentUsername || "?").charAt(0).toUpperCase()}</div>
          <div style="flex:1">
            <div class="agent-item-name">${data.agentName || data.agentUsername}</div>
            <div class="agent-item-handle">@${data.agentUsername}</div>
          </div>
          <button class="btn-remove" onclick="removeFromAgent('${d.id}', '${data.agentUid}', '${phone}', '${data.agentName || data.agentUsername}')">
            Remove
          </button>
        `;
        listEl.appendChild(item);
      });

      const count = snap.docs.length;
      limitEl.innerHTML = `${count} / ${MAX_AGENTS} agent slots used.` +
        (count >= MAX_AGENTS ? ` <span class="limit-hit">Limit reached.</span>` : "");
    }

    section.style.display = "block";
    setLoading("del-lookup-btn", false, "Look Up My Registrations");

  } catch (e) {
    errEl.textContent = "Lookup failed: " + e.message;
    errEl.style.display = "block";
    setLoading("del-lookup-btn", false, "Look Up My Registrations");
  }
};

// ─── REMOVE FROM AGENT ────────────────────────────────────────────────────────
window.removeFromAgent = async function(regDocId, agentUidTarget, phone, agentDisplayName) {
  if (!confirm(`Remove yourself from ${agentDisplayName}'s client list?\n\nThis will sync to their app immediately if they're online.`)) return;

  try {
    // 1. Delete from clientRegistrations
    await deleteDoc(doc(db, "clientRegistrations", regDocId));

    // 2. Delete from agents/{agentUid}/clients/{phone}
    await deleteDoc(doc(db, "agents", agentUidTarget, "clients", phone));

    // Show success
    $("del-form").style.display    = "none";
    $("delete-state").style.display = "block";
    $("delete-desc").textContent   =
      `You have been removed from ${agentDisplayName}'s client list. This change syncs to their app instantly.`;

  } catch (e) {
    const errEl = $("del-err");
    errEl.textContent = "Removal failed: " + e.message;
    errEl.style.display = "block";
  }
};

// ─── Helper: build masked fingerprint from full phone number ─────────────────
// Mirrors the Kotlin logic in MpesaSmsParser.fingerprintFromFullPhone()
// 07XXYYYZZZ → MID:XX_ZZZ
function buildFingerprint(phone) {
  const p = phone.trim();
  if (!/^(07|01)\d{8}$/.test(p)) return "";
  const mid  = p.substring(2, 4);   // characters at index 2 and 3
  const last = p.slice(-3);
  return `MID:${mid}_${last}`;
}

// ─── Theme ────────────────────────────────────────────────────────────────────
const _h = document.documentElement;
_h.setAttribute("data-theme", localStorage.getItem("bf-theme") || "dark");

function _tb() {
  const b = $("tb");
  if (!b) return;
  const dark = _h.getAttribute("data-theme") === "dark";
  b.innerHTML = dark
    ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`
    : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>`;
}

window.toggleTheme = function() {
  const t = _h.getAttribute("data-theme") === "dark" ? "light" : "dark";
  _h.setAttribute("data-theme", t);
  localStorage.setItem("bf-theme", t);
  _tb();
};

_tb();

// ─── Start ────────────────────────────────────────────────────────────────────
init();
</script>

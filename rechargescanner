  <main>
    <section class="hero">
      <div class="hero-copy">
        <span class="eyebrow"><span class="dot"></span> Privacy Policy</span>
        <h1>Airtime Recharge Scanner</h1>
        <p class="lead">This Privacy Policy explains how Airtime Recharge Scanner handles voucher digits, SIM and carrier details, USSD responses, app permissions, advertising, and local history when you scan or enter airtime recharge cards.</p>
      </div>
      <aside class="summary-card" aria-label="Policy summary">
        <div class="summary-row">
          <span class="summary-icon">1</span>
          <span><strong>Effective date</strong><span>May 17, 2026</span></span>
        </div>
        <div class="summary-row">
          <span class="summary-icon">2</span>
          <span><strong>Published URL</strong><span>bingwaflash.co.ke/rechargescanner/privacy</span></span>
        </div>
        <div class="summary-row">
          <span class="summary-icon">3</span>
          <span><strong>Main promise</strong><span>Recharge data is used to run the actions you choose, keep history on your device, and improve the app experience.</span></span>
        </div>
      </aside>
    </section>

    <section class="layout">
      <aside class="toc" aria-label="Table of contents">
        <div class="toc-title">Policy Sections</div>

  <link rel="icon" type="image/png" href="/logo.png" />
  <style>
    :root {
      color-scheme: dark light;
      --red: #F90106;
      --red-deep: #980006;
      --red-soft: rgba(249, 1, 6, 0.13);
      --black: #000000;
      --ink: #111014;
      --muted: #6f7078;
      --line: rgba(249, 1, 6, 0.24);
      --paper: #ffffff;
      --paper-soft: #fff7f8;
      --card: #ffffff;
      --shadow: 0 22px 70px rgba(92, 0, 4, 0.16);
      --radius: 26px;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --ink: #f8f8fb;
        --muted: #a9a9b3;
        --line: rgba(249, 1, 6, 0.34);
        --paper: #000000;
        --paper-soft: #08080b;
        --card: #17070a;
        --shadow: 0 22px 70px rgba(249, 1, 6, 0.18);
      }
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      line-height: 1.68;
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(circle at 14% 4%, rgba(249, 1, 6, 0.18), transparent 28rem),
        radial-gradient(circle at 90% 10%, rgba(152, 0, 6, 0.16), transparent 24rem),
        linear-gradient(180deg, var(--paper-soft), var(--paper));
    }

    a { color: var(--red); text-decoration: none; font-weight: 800; }
    a:hover { text-decoration: underline; }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      background: linear-gradient(135deg, var(--red), var(--red-deep));
      color: #ffffff;
      border-bottom: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow: 0 12px 34px rgba(152, 0, 6, 0.28);
    }

    .topbar-inner {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto;
      min-height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 13px;
      color: #ffffff;
      text-decoration: none;
    }

    .brand-mark {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: #ffffff;
      box-shadow: inset 0 0 0 1px rgba(249, 1, 6, 0.14), 0 10px 24px rgba(0, 0, 0, 0.18);
      color: var(--red);
      font-weight: 950;
      letter-spacing: -0.08em;
    }

    .brand-title { font-size: 1rem; font-weight: 900; line-height: 1.1; }
    .brand-sub { font-size: 0.78rem; opacity: 0.86; font-weight: 650; }

    .toplinks {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .toplinks a {
      color: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.26);
      border-radius: 999px;
      padding: 8px 13px;
      font-size: 0.84rem;
      background: rgba(255, 255, 255, 0.11);
      text-decoration: none;
    }

    .hero {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto;
      padding: 62px 0 34px;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 28px;
      align-items: stretch;
    }

    .hero-copy,
    .summary-card,
    .policy-card,
    .contact-card {
      border: 1px solid var(--line);
      background: color-mix(in srgb, var(--card) 92%, var(--red) 8%);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .hero-copy { padding: 34px; }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--red-soft);
      color: var(--red);
      font-size: 0.78rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .dot { width: 9px; height: 9px; border-radius: 99px; background: var(--red); box-shadow: 0 0 0 7px rgba(249, 1, 6, 0.13); }
    h1 { margin: 22px 0 14px; font-size: clamp(2.15rem, 6vw, 4.25rem); line-height: 0.98; letter-spacing: -0.055em; }
    .lead { max-width: 760px; margin: 0; color: var(--muted); font-size: clamp(1.03rem, 2vw, 1.2rem); font-weight: 560; }

    .summary-card {
      padding: 26px;
      display: grid;
      align-content: center;
      gap: 18px;
      background:
        linear-gradient(135deg, rgba(249, 1, 6, 0.25), rgba(152, 0, 6, 0.06)),
        var(--card);
    }

    .summary-row { display: grid; grid-template-columns: 42px 1fr; gap: 12px; align-items: start; }
    .summary-icon {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: var(--red);
      color: #ffffff;
      font-weight: 900;
    }
    .summary-row strong { display: block; font-size: 0.98rem; }
    .summary-row span { display: block; color: var(--muted); font-size: 0.91rem; margin-top: 2px; }

    .layout {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto 72px;
      display: grid;
      grid-template-columns: 268px 1fr;
      gap: 26px;
      align-items: start;
    }

    .toc {
      position: sticky;
      top: 98px;
      border: 1px solid var(--line);
      background: color-mix(in srgb, var(--card) 94%, var(--red) 6%);
      border-radius: 22px;
      padding: 16px;
      box-shadow: 0 16px 44px rgba(92, 0, 4, 0.1);
    }

    .toc-title { color: var(--red); font-weight: 950; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 4px 0 10px; }
    .toc a { display: block; color: var(--muted); padding: 8px 10px; border-radius: 12px; font-size: 0.9rem; font-weight: 800; text-decoration: none; }
    .toc a:hover { color: var(--red); background: var(--red-soft); }

    .policy-stack { display: grid; gap: 18px; }
    .policy-card { padding: 26px; }
    .policy-card h2 { margin: 0 0 12px; font-size: clamp(1.28rem, 3vw, 1.72rem); letter-spacing: -0.03em; display: flex; gap: 12px; align-items: center; }
    .section-no { min-width: 34px; height: 34px; border-radius: 12px; display: inline-grid; place-items: center; background: var(--red); color: #ffffff; font-size: 0.82rem; }
    .policy-card p { margin: 0 0 12px; color: var(--muted); font-weight: 540; }
    .policy-card p:last-child { margin-bottom: 0; }
    .policy-card ul { margin: 10px 0 4px; padding: 0; list-style: none; display: grid; gap: 10px; }
    .policy-card li { position: relative; padding-left: 23px; color: var(--muted); font-weight: 540; }
    .policy-card li::before { content: ""; width: 8px; height: 8px; border-radius: 99px; position: absolute; top: 0.68em; left: 0; background: var(--red); box-shadow: 0 0 0 5px rgba(249, 1, 6, 0.1); }
    .policy-card strong { color: var(--ink); font-weight: 900; }

    .notice {
      margin-top: 14px;
      border: 1px dashed var(--line);
      border-radius: 18px;
      background: var(--red-soft);
      padding: 14px 16px;
      color: var(--ink);
      font-weight: 740;
    }

    .contact-card {
      padding: 28px;
      background: linear-gradient(135deg, var(--red), var(--red-deep));
      color: #ffffff;
      overflow: hidden;
      position: relative;
    }
    .contact-card::after { content: ""; position: absolute; width: 280px; height: 280px; border-radius: 999px; right: -90px; top: -130px; background: rgba(255, 255, 255, 0.12); }
    .contact-card h2, .contact-card p { position: relative; z-index: 1; }
    .contact-card h2 { margin: 0 0 8px; font-size: 1.7rem; letter-spacing: -0.04em; }
    .contact-card p { margin: 0; opacity: 0.92; }
    .contact-card a { color: #ffffff; text-decoration: underline; }

    footer {
      border-top: 1px solid var(--line);
      color: var(--muted);
      padding: 28px 0 40px;
      text-align: center;
      font-size: 0.92rem;
    }

    @media (max-width: 860px) {
      .topbar-inner { min-height: 70px; }
      .toplinks { display: none; }
      .hero { grid-template-columns: 1fr; padding-top: 34px; }
      .hero-copy { padding: 24px; }
      .layout { grid-template-columns: 1fr; }
      .toc { position: static; }
    }
